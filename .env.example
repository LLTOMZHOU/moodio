# Copy this file to .env and fill in local values.
# .env is ignored by git and is meant to override any shell-wide keys.

# OpenRouter-backed model path. OPENAI_API_KEY is kept empty so local loaders can
# explicitly choose OPENROUTER_API_KEY instead of accidentally using a global key.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.4-mini
MOODIO_AGENT_TIMEOUT_SECONDS=45

# Direct OpenAI Speech API path for future TTS/STT. This is separate from
# OpenRouter because speech endpoints are OpenAI Audio API endpoints.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
OPENAI_TTS_RESPONSE_FORMAT=mp3
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optional SoundCloud API path. Not required for SoundCloud embeds.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_OAUTH_TOKEN=

# Optional MiniMax generation path for future station IDs/interludes.
MINIMAX_API_KEY=
