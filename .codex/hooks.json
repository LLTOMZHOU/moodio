{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/sync_branch_on_session_start.py\"",
            "statusMessage": "Syncing Git branch on session start"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/request_codex_review.py\"",
            "statusMessage": "Requesting Codex review for new PR"
          },
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/request_copilot_review.py\"",
            "statusMessage": "Requesting Copilot review for new PR"
          }
        ]
      }
    ]
  }
}
